# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project-id.supabase.co:5432/postgres

# ── Backend ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.onrender.com
ENVIRONMENT=development   # development | production

# ── Frontend (Vite env vars must be prefixed VITE_) ────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
